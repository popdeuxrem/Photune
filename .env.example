# ============================================
# PHOTUNE ENVIRONMENT TEMPLATE
# ============================================

# --------------------------------------------
# CORE RUNTIME (required in all environments)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --------------------------------------------
# AI PROVIDERS (required when AI features are enabled)
# --------------------------------------------

# Groq: text rewrite / text generation
GROQ_API_KEY=

# Cloudflare: image operations / worker-backed AI routes
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --------------------------------------------
# PAYMENT PROVIDERS (Canonical: Stripe only)
# --------------------------------------------

# Stripe (active)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=

# --------------------------------------------
# OPTIONAL / DEFERRED PROVIDERS

# --------------------------------------------
# EMAIL
# Choose exactly one provider in implementation.
# Do not enable both long-term without explicit fallback policy.
# --------------------------------------------

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
